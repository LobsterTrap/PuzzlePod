<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net" modified="2026-03-06" agent="Claude" version="24.0">
  <diagram id="network-gating-flow" name="Network Gating Flow">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="title" value="Network Gating: Three Isolation Modes" style="text;html=1;fontSize=20;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="400" y="20" width="800" height="40" as="geometry"/>
        </mxCell>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- MODE 1: BLOCKED (left column)                       -->
        <!-- ═══════════════════════════════════════════════════ -->

        <mxCell id="blocked-title" value="BLOCKED MODE" style="text;html=1;fontSize=16;fontStyle=1;align=center;fontColor=#CC0000;" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="440" height="30" as="geometry"/>
        </mxCell>

        <!-- Agent in blocked namespace -->
        <mxCell id="blocked-ns" value="" style="rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;dashed=1;dashPattern=5 5;" vertex="1" parent="1">
          <mxGeometry x="60" y="120" width="400" height="280" as="geometry"/>
        </mxCell>
        <mxCell id="blocked-ns-label" value="Network Namespace (empty)" style="text;html=1;fontSize=12;fontStyle=1;align=left;verticalAlign=top;fontColor=#CC0000;" vertex="1" parent="1">
          <mxGeometry x="70" y="125" width="250" height="20" as="geometry"/>
        </mxCell>

        <mxCell id="blocked-agent" value="&lt;b&gt;Agent Process&lt;/b&gt;&lt;br&gt;(PID 1 in ns)" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="160" y="160" width="200" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="blocked-no-iface" value="No interfaces up&lt;br&gt;(lo down by default)" style="text;html=1;fontSize=11;align=center;fontColor=#999999;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="160" y="230" width="200" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="blocked-x1" value="✗ connect() → ENETUNREACH" style="text;html=1;fontSize=11;fontColor=#CC0000;align=center;" vertex="1" parent="1">
          <mxGeometry x="120" y="270" width="280" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="blocked-x2" value="✗ bind() → EADDRNOTAVAIL" style="text;html=1;fontSize=11;fontColor=#CC0000;align=center;" vertex="1" parent="1">
          <mxGeometry x="120" y="295" width="280" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="blocked-x3" value="✗ sendto() → ENETUNREACH" style="text;html=1;fontSize=11;fontColor=#CC0000;align=center;" vertex="1" parent="1">
          <mxGeometry x="120" y="320" width="280" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="blocked-x4" value="✗ DNS resolution fails" style="text;html=1;fontSize=11;fontColor=#CC0000;align=center;" vertex="1" parent="1">
          <mxGeometry x="120" y="345" width="280" height="20" as="geometry"/>
        </mxCell>

        <mxCell id="blocked-summary" value="Zero network access.&lt;br&gt;Kernel-enforced — no userspace bypass possible." style="text;html=1;fontSize=10;align=center;fontStyle=2;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="80" y="380" width="360" height="30" as="geometry"/>
        </mxCell>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- MODE 2: GATED (center column)                       -->
        <!-- ═══════════════════════════════════════════════════ -->

        <mxCell id="gated-title" value="GATED MODE" style="text;html=1;fontSize=16;fontStyle=1;align=center;fontColor=#CC8800;" vertex="1" parent="1">
          <mxGeometry x="530" y="80" width="540" height="30" as="geometry"/>
        </mxCell>

        <!-- Gated namespace -->
        <mxCell id="gated-ns" value="" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;dashed=1;dashPattern=5 5;" vertex="1" parent="1">
          <mxGeometry x="530" y="120" width="540" height="520" as="geometry"/>
        </mxCell>
        <mxCell id="gated-ns-label" value="Network Namespace (gated)" style="text;html=1;fontSize=12;fontStyle=1;align=left;verticalAlign=top;fontColor=#CC8800;" vertex="1" parent="1">
          <mxGeometry x="540" y="125" width="250" height="20" as="geometry"/>
        </mxCell>

        <!-- Agent -->
        <mxCell id="gated-agent" value="&lt;b&gt;Agent Process&lt;/b&gt;&lt;br&gt;HTTP_PROXY=127.0.0.1:8080" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="650" y="160" width="250" height="50" as="geometry"/>
        </mxCell>

        <!-- veth pair -->
        <mxCell id="gated-veth-ns" value="veth-gated-ns&lt;br&gt;10.200.1.2/24" style="rounded=1;whiteSpace=wrap;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="570" y="250" width="140" height="50" as="geometry"/>
        </mxCell>

        <!-- HTTP request flow -->
        <mxCell id="gated-arrow-1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#6c8ebf;" edge="1" parent="1" source="gated-agent" target="gated-veth-ns">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="gated-arrow-1-label" value="HTTP request" style="edgeLabel;fontSize=9;" vertex="1" connectable="0" parent="gated-arrow-1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- nftables box -->
        <mxCell id="gated-nft" value="&lt;b&gt;nftables filter&lt;/b&gt;&lt;br&gt;(kernel, inet table)&lt;br&gt;&lt;br&gt;ALLOW: TCP 53, 443&lt;br&gt;ALLOW: UDP 53&lt;br&gt;ALLOW: ct established&lt;br&gt;DROP: everything else" style="rounded=1;whiteSpace=wrap;fillColor=#f5f5f5;strokeColor=#CC8800;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="570" y="340" width="190" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="gated-arrow-2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#CC8800;" edge="1" parent="1" source="gated-veth-ns" target="gated-nft">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Host-side veth -->
        <mxCell id="gated-veth-host" value="veth-gated-h&lt;br&gt;10.200.1.1/24" style="rounded=1;whiteSpace=wrap;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="570" y="500" width="140" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="gated-arrow-3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#CC8800;" edge="1" parent="1" source="gated-nft" target="gated-veth-host">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="gated-arrow-3-label" value="if allowed" style="edgeLabel;fontSize=9;fontColor=#009900;" vertex="1" connectable="0" parent="gated-arrow-3">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- HTTP Proxy (host side) -->
        <mxCell id="gated-proxy" value="&lt;b&gt;puzzle-proxy&lt;/b&gt;&lt;br&gt;(ProxyServer)&lt;br&gt;&lt;br&gt;Domain allowlist check&lt;br&gt;Method filtering&lt;br&gt;Journal capture" style="rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="800" y="250" width="200" height="100" as="geometry"/>
        </mxCell>

        <!-- Journal -->
        <mxCell id="gated-journal" value="&lt;b&gt;NetworkJournal&lt;/b&gt;&lt;br&gt;(NDJSON file)&lt;br&gt;&lt;br&gt;POST/PUT/DELETE&lt;br&gt;→ journaled&lt;br&gt;(replay at commit)" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="830" y="400" width="170" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="gated-arrow-proxy-journal" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#d6b656;dashed=1;" edge="1" parent="1" source="gated-proxy" target="gated-journal">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="gated-arrow-pj-label" value="mutating requests" style="edgeLabel;fontSize=9;fontColor=#CC8800;" vertex="1" connectable="0" parent="gated-arrow-proxy-journal">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Decision boxes from proxy -->
        <mxCell id="gated-403" value="403 Forbidden&lt;br&gt;(blocked domain)" style="rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="820" y="160" width="130" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="gated-202" value="202 Accepted&lt;br&gt;(journaled for replay)" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="960" y="160" width="130" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="gated-200" value="200 OK&lt;br&gt;(GET forwarded)" style="rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="960" y="310" width="130" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="gated-arrow-403" style="rounded=1;strokeColor=#b85450;" edge="1" parent="1" source="gated-proxy" target="gated-403">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="gated-arrow-202" style="rounded=1;strokeColor=#d6b656;" edge="1" parent="1" source="gated-proxy" target="gated-202">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="gated-arrow-200" style="rounded=1;strokeColor=#82b366;" edge="1" parent="1" source="gated-proxy" target="gated-200">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- MODE 3: MONITORED (right column)                    -->
        <!-- ═══════════════════════════════════════════════════ -->

        <mxCell id="mon-title" value="MONITORED MODE" style="text;html=1;fontSize=16;fontStyle=1;align=center;fontColor=#009900;" vertex="1" parent="1">
          <mxGeometry x="1130" y="80" width="440" height="30" as="geometry"/>
        </mxCell>

        <!-- Monitored namespace -->
        <mxCell id="mon-ns" value="" style="rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;dashed=1;dashPattern=5 5;" vertex="1" parent="1">
          <mxGeometry x="1130" y="120" width="440" height="520" as="geometry"/>
        </mxCell>
        <mxCell id="mon-ns-label" value="Network Namespace (monitored)" style="text;html=1;fontSize=12;fontStyle=1;align=left;verticalAlign=top;fontColor=#009900;" vertex="1" parent="1">
          <mxGeometry x="1140" y="125" width="280" height="20" as="geometry"/>
        </mxCell>

        <!-- Agent -->
        <mxCell id="mon-agent" value="&lt;b&gt;Agent Process&lt;/b&gt;&lt;br&gt;(full network access)" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="1240" y="160" width="220" height="50" as="geometry"/>
        </mxCell>

        <!-- veth pair -->
        <mxCell id="mon-veth-ns" value="veth-mon-ns&lt;br&gt;10.200.2.2/24" style="rounded=1;whiteSpace=wrap;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="1230" y="260" width="140" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="mon-arrow-1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#6c8ebf;" edge="1" parent="1" source="mon-agent" target="mon-veth-ns">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- nftables logging -->
        <mxCell id="mon-nft" value="&lt;b&gt;nftables log&lt;/b&gt;&lt;br&gt;(kernel, inet table)&lt;br&gt;&lt;br&gt;policy: ACCEPT&lt;br&gt;log prefix: &quot;puzzled-monitored:&quot;" style="rounded=1;whiteSpace=wrap;fillColor=#f5f5f5;strokeColor=#009900;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="1200" y="350" width="200" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="mon-arrow-2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#009900;" edge="1" parent="1" source="mon-veth-ns" target="mon-nft">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Host veth -->
        <mxCell id="mon-veth-host" value="veth-mon-h&lt;br&gt;10.200.2.1/24" style="rounded=1;whiteSpace=wrap;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="1230" y="500" width="140" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="mon-arrow-3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#009900;" edge="1" parent="1" source="mon-nft" target="mon-veth-host">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="mon-arrow-3-label" value="all traffic passes" style="edgeLabel;fontSize=9;fontColor=#009900;" vertex="1" connectable="0" parent="mon-arrow-3">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Kernel log -->
        <mxCell id="mon-klog" value="&lt;b&gt;Kernel Log&lt;/b&gt;&lt;br&gt;(dmesg / journald)&lt;br&gt;&lt;br&gt;Every packet logged&lt;br&gt;with prefix for&lt;br&gt;audit correlation" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="1420" y="350" width="140" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="mon-arrow-log" style="rounded=1;strokeColor=#d6b656;dashed=1;" edge="1" parent="1" source="mon-nft" target="mon-klog">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Internet -->
        <mxCell id="mon-internet" value="&lt;b&gt;Internet&lt;/b&gt;&lt;br&gt;(unrestricted)" style="ellipse;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="1240" y="580" width="130" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="mon-arrow-inet" style="rounded=1;strokeColor=#009900;" edge="1" parent="1" source="mon-veth-host" target="mon-internet">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- Legend at bottom                                    -->
        <!-- ═══════════════════════════════════════════════════ -->

        <mxCell id="legend-box" value="" style="rounded=1;whiteSpace=wrap;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="40" y="680" width="1530" height="280" as="geometry"/>
        </mxCell>
        <mxCell id="legend-title" value="Network Gating Architecture" style="text;html=1;fontSize=14;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="60" y="690" width="300" height="25" as="geometry"/>
        </mxCell>

        <!-- Comparison table -->
        <mxCell id="legend-table" value="&lt;table style='font-size:11px;border-collapse:collapse;width:100%'&gt;&lt;tr style='background:#eee;font-weight:bold'&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;Property&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc;color:#CC0000'&gt;Blocked&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc;color:#CC8800'&gt;Gated&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc;color:#009900'&gt;Monitored&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;Network Namespace&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;Empty (no interfaces)&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;veth pair (10.200.1.0/24)&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;veth pair (10.200.2.0/24)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;nftables Policy&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;N/A&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;DROP (allow DNS+HTTPS)&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;ACCEPT (log all)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;HTTP Proxy&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;N/A&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;Domain filtering + journal&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;Optional (logging only)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;Side-effect Handling&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;Impossible&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;POST/PUT/DELETE journaled → replay at commit&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;All traffic allowed (logged)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;Enforcement&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;Kernel (namespace)&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;Kernel (nftables) + Userspace (proxy)&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;Kernel (nftables log)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;Survives puzzled Crash&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;Yes (kernel namespace)&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;Yes (nftables persist)&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;Yes (nftables persist)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;Use Case&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;Air-gapped, safety-critical&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;Standard agent (API calls)&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;Trusted agent (audit trail)&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="text;html=1;overflow=fill;" vertex="1" parent="1">
          <mxGeometry x="60" y="720" width="1490" height="220" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
