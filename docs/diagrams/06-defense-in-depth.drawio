<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net" modified="2026-03-06" agent="Claude" version="24.0">
  <diagram id="defense-in-depth" name="Defense-in-Depth: 8 Independent Enforcement Layers">
    <mxGraphModel dx="1400" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="title" value="Defense-in-Depth: 8 Independent Enforcement Layers" style="text;html=1;fontSize=20;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="300" y="20" width="1000" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="subtitle" value="Every escape vector is blocked by at least two independent mechanisms. Each layer survives failure of all others." style="text;html=1;fontSize=12;fontStyle=2;align=center;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="300" y="55" width="1000" height="25" as="geometry"/>
        </mxCell>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- Agent at center                                     -->
        <!-- ═══════════════════════════════════════════════════ -->

        <mxCell id="agent" value="&lt;b&gt;Agent Process&lt;/b&gt;&lt;br&gt;&lt;br&gt;LLM-driven&lt;br&gt;Untrusted control flow&lt;br&gt;Trusted identity" style="ellipse;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="660" y="370" width="200" height="130" as="geometry"/>
        </mxCell>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- Layer 0: Landlock (innermost ring)                  -->
        <!-- ═══════════════════════════════════════════════════ -->

        <mxCell id="layer0" value="" style="ellipse;whiteSpace=wrap;fillColor=none;strokeColor=#CC0000;strokeWidth=3;dashed=0;" vertex="1" parent="1">
          <mxGeometry x="520" y="240" width="480" height="390" as="geometry"/>
        </mxCell>
        <mxCell id="layer0-label" value="Layer 0: Landlock LSM" style="text;html=1;fontSize=11;fontStyle=1;fontColor=#CC0000;align=center;" vertex="1" parent="1">
          <mxGeometry x="640" y="245" width="240" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="layer0-box" value="&lt;b&gt;Landlock LSM&lt;/b&gt; (ABI v4, kernel 6.7+)&lt;br&gt;&lt;br&gt;• Irrevocable filesystem ACL per-process&lt;br&gt;• Read/write/exec path restrictions&lt;br&gt;• Network connect/bind port restrictions&lt;br&gt;• &lt; 1 μs per check (in-kernel)&lt;br&gt;• Survives puzzled crash: &lt;b&gt;YES&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="100" width="280" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="layer0-arrow" style="rounded=1;strokeColor=#CC0000;dashed=1;" edge="1" parent="1" source="layer0-box" target="layer0">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- Layer 1: seccomp-BPF                                -->
        <!-- ═══════════════════════════════════════════════════ -->

        <mxCell id="layer1-box" value="&lt;b&gt;seccomp-BPF&lt;/b&gt; (kernel 3.5+/5.0+)&lt;br&gt;&lt;br&gt;• Tier 1: Static deny 57 escape syscalls&lt;br&gt;  (ptrace, mount, kexec, bpf, shmget...)&lt;br&gt;• Tier 2: USER_NOTIF for execve/connect/bind&lt;br&gt;  (daemon-mediated, ~50-100 μs)&lt;br&gt;• Survives puzzled crash: &lt;b&gt;YES&lt;/b&gt;&lt;br&gt;  (static filter keeps blocking)" style="rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1280" y="100" width="280" height="130" as="geometry"/>
        </mxCell>
        <mxCell id="layer1-arrow" style="rounded=1;strokeColor=#CC0000;dashed=1;" edge="1" parent="1" source="layer1-box" target="layer0">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- Layer 2: PID Namespace                              -->
        <!-- ═══════════════════════════════════════════════════ -->

        <mxCell id="layer2-box" value="&lt;b&gt;PID Namespace&lt;/b&gt; (kernel 3.8+)&lt;br&gt;&lt;br&gt;• Agent is PID 1 in its namespace&lt;br&gt;• Cannot see/signal host processes&lt;br&gt;• Kill namespace → kill all agent procs&lt;br&gt;• pidfd for race-free monitoring&lt;br&gt;• Survives puzzled crash: &lt;b&gt;YES&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="280" width="260" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="layer2-arrow" style="rounded=1;strokeColor=#9673a6;dashed=1;" edge="1" parent="1" source="layer2-box" target="layer0">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- Layer 3: Mount Namespace + OverlayFS                -->
        <!-- ═══════════════════════════════════════════════════ -->

        <mxCell id="layer3-box" value="&lt;b&gt;Mount Namespace + OverlayFS&lt;/b&gt;&lt;br&gt;&lt;br&gt;• Isolated filesystem view per agent&lt;br&gt;• Copy-on-write branching (upper layer)&lt;br&gt;• Writes never touch base filesystem&lt;br&gt;• Rollback = delete upper dir (zero residue)&lt;br&gt;• Survives puzzled crash: &lt;b&gt;YES&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1280" y="290" width="280" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="layer3-arrow" style="rounded=1;strokeColor=#9673a6;dashed=1;" edge="1" parent="1" source="layer3-box" target="layer0">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- Layer 4: Network Namespace                          -->
        <!-- ═══════════════════════════════════════════════════ -->

        <mxCell id="layer4-box" value="&lt;b&gt;Network Namespace&lt;/b&gt; (kernel 2.6.29+)&lt;br&gt;&lt;br&gt;• Three modes: Blocked / Gated / Monitored&lt;br&gt;• veth pair for controlled connectivity&lt;br&gt;• nftables for port filtering + logging&lt;br&gt;• Agent cannot modify host network stack&lt;br&gt;• Survives puzzled crash: &lt;b&gt;YES&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="470" width="280" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="layer4-arrow" style="rounded=1;strokeColor=#d6b656;dashed=1;" edge="1" parent="1" source="layer4-box" target="layer0">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- Layer 5: cgroups v2                                 -->
        <!-- ═══════════════════════════════════════════════════ -->

        <mxCell id="layer5-box" value="&lt;b&gt;cgroups v2&lt;/b&gt; (kernel 4.5+)&lt;br&gt;&lt;br&gt;• Memory limit (OOM killer enforced)&lt;br&gt;• CPU shares / weight&lt;br&gt;• I/O bandwidth limits&lt;br&gt;• PID count limits (fork bomb protection)&lt;br&gt;• cgroup.freeze for TOCTOU protection&lt;br&gt;• Survives puzzled crash: &lt;b&gt;YES&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1280" y="470" width="280" height="130" as="geometry"/>
        </mxCell>
        <mxCell id="layer5-arrow" style="rounded=1;strokeColor=#d6b656;dashed=1;" edge="1" parent="1" source="layer5-box" target="layer0">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- Layer 6: SELinux                                    -->
        <!-- ═══════════════════════════════════════════════════ -->

        <mxCell id="layer6-box" value="&lt;b&gt;SELinux&lt;/b&gt; (kernel 2.6+)&lt;br&gt;&lt;br&gt;• puzzlepod_t domain (type enforcement)&lt;br&gt;• neverallow: ptrace, module_load,&lt;br&gt;  SELinux policy modification&lt;br&gt;• MCS labels for multi-tenancy&lt;br&gt;• Survives puzzled crash: &lt;b&gt;YES&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="660" width="280" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="layer6-arrow" style="rounded=1;strokeColor=#82b366;dashed=1;" edge="1" parent="1" source="layer6-box" target="layer0">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- Layer 7: BPF LSM                                    -->
        <!-- ═══════════════════════════════════════════════════ -->

        <mxCell id="layer7-box" value="&lt;b&gt;BPF LSM&lt;/b&gt; (kernel 5.7+)&lt;br&gt;&lt;br&gt;• bprm_check_security hook&lt;br&gt;• Per-cgroup exec rate limiting&lt;br&gt;• Counters in BPF maps&lt;br&gt;• &lt; 1 μs per check (in-kernel)&lt;br&gt;• Survives puzzled crash: &lt;b&gt;YES&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1280" y="660" width="280" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="layer7-arrow" style="rounded=1;strokeColor=#82b366;dashed=1;" edge="1" parent="1" source="layer7-box" target="layer0">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- Monitoring layer (not enforcement)                  -->
        <!-- ═══════════════════════════════════════════════════ -->

        <mxCell id="monitoring-box" value="&lt;b&gt;Monitoring Layer (not enforcement)&lt;/b&gt;&lt;br&gt;&lt;br&gt;• fanotify: real-time file access monitoring, behavioral triggers&lt;br&gt;• Linux Audit: security event logging&lt;br&gt;• IMA: integrity measurement for changeset signing&lt;br&gt;• AuditStore: persistent NDJSON event storage with query" style="rounded=1;whiteSpace=wrap;fillColor=#f5f5f5;strokeColor=#999999;fontSize=10;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="520" y="690" width="480" height="100" as="geometry"/>
        </mxCell>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- Escape vector coverage table                        -->
        <!-- ═══════════════════════════════════════════════════ -->

        <mxCell id="table-title" value="Escape Vector Coverage Matrix" style="text;html=1;fontSize=14;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="300" y="840" width="1000" height="25" as="geometry"/>
        </mxCell>

        <mxCell id="table" value="&lt;table style='font-size:10px;border-collapse:collapse;width:100%'&gt;&lt;tr style='background:#eee;font-weight:bold'&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;Escape Vector&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;Landlock&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;seccomp&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;PID NS&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;Mount NS&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;Net NS&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;cgroups&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;SELinux&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;BPF LSM&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;Read /etc/shadow&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc;color:green'&gt;BLOCK&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;—&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;—&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;—&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;—&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;—&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc;color:green'&gt;BLOCK&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;—&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;ptrace(puzzled)&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;—&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc;color:green'&gt;BLOCK&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc;color:green'&gt;BLOCK&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;—&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;—&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;—&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc;color:green'&gt;BLOCK&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;—&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;Fork bomb&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;—&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;—&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;—&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;—&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;—&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc;color:green'&gt;BLOCK&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;—&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc;color:green'&gt;BLOCK&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;exec(curl attacker.com)&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;—&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc;color:green'&gt;GATE&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;—&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;—&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc;color:green'&gt;BLOCK&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;—&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;—&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc;color:green'&gt;RATE&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;connect(C2 server)&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc;color:green'&gt;BLOCK&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc;color:green'&gt;GATE&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;—&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;—&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc;color:green'&gt;BLOCK&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;—&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;—&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;—&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;mount(proc, /)&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;—&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc;color:green'&gt;BLOCK&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;—&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc;color:green'&gt;BLOCK&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;—&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;—&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc;color:green'&gt;BLOCK&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;—&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;Write /etc/crontab&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc;color:green'&gt;BLOCK&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;—&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;—&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc;color:green'&gt;CoW&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;—&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;—&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc;color:green'&gt;BLOCK&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;—&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;Memory exhaustion&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;—&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;—&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;—&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;—&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;—&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc;color:green'&gt;OOM&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;—&lt;/td&gt;&lt;td style='padding:4px;border:1px solid #ccc'&gt;—&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="text;html=1;overflow=fill;" vertex="1" parent="1">
          <mxGeometry x="100" y="870" width="1400" height="290" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
